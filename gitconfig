[user]
    name = Tyler Pearson
    email = tpearson@gmail.com
[color]
    status = auto
    branch = auto
    diff = auto
[alias]
    co = checkout
    st = status
    fix = commit --amend --no-edit
[branch]
    autoSetupRebase = always
[push]
    default = simple
    autoSetupRemote = true
[pull]
    rebase = true
[rebase]
    autoSquash = true
    autoStash = true
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = dimmed-zebra
    color-moved-ws = ignore-all-space
[rerere]
    enabled = true
    autoUpdate = true
[core]
    excludesFile=~/.gitignore_global
