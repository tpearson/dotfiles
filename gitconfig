[user]
        name = Tyler Pearson
        email = tpearson@gmail.com
[color]
        status = auto
        branch = auto
        diff = auto
[alias]
        co = checkout
        st = status
        fix = commit --amend --no-edit
[branch]
        autoSetupRebase = always
[push]
    default = simple
    autoSetupRemote = true
[rebase]
        autostash = true
[merge]
        conflictstyle = diff3
[diff]
        colorMoved = dimmed-zebra
        color-moved-ws = ignore-all-space
